<idea-plugin>
    <id>com.terminalsnippets.plugin</id>
    <name>Terminal Command Snippets</name>
    <version>1.0.2</version>
    <vendor>EICK.IT GmbH</vendor>

    <description><![CDATA[
        <b>Terminal Command Snippets</b> – Categorized terminal commands at the click of a button.<br/><br/>
        <ul>
            <li>Manage snippets and categories under <b>File → Settings → Tools → Terminal Command Snippets</b></li>
            <li>Dropdown button directly in the terminal toolbar</li>
            <li>Keyboard shortcut: <b>Alt+Shift+S</b></li>
        </ul>
        Pre-defined categories: Symfony, Composer, WP-CLI, Git.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <extensions defaultExtensionNs="com.intellij">

        <applicationService
            serviceImplementation="com.terminalsnippets.settings.TerminalSnippetsState"/>

        <applicationConfigurable
            parentId="tools"
            instance="com.terminalsnippets.settings.TerminalSnippetsConfigurable"
            id="com.terminalsnippets.settings.TerminalSnippetsConfigurable"
            displayName="Terminal Command Snippets"/>

        <!-- Notification group for feedback balloons -->
        <notificationGroup id="Terminal Command Snippets"
            displayType="BALLOON"
            isLogByDefault="true"/>

    </extensions>

    <actions>

        <!--
            Dropdown button in the terminal toolbar.
            popup="true" creates a native IntelliJ dropdown button.
            TerminalToolwindowActionGroup is the correct group ID in PhpStorm 2025.x
        -->
        <group
            id="com.terminalsnippets.actions.SnippetActionGroup"
            class="com.terminalsnippets.actions.SnippetActionGroup"
            text="Terminal Command Snippets"
            description="Select and insert a terminal command snippet"
            icon="AllIcons.Actions.ListChanges"
            popup="true">

            <add-to-group group-id="TerminalToolwindowActionGroup" anchor="last"/>
        </group>

        <!-- Keyboard shortcut: separate action that opens the popup -->
        <action
            id="com.terminalsnippets.actions.OpenSnippetsPopupAction"
            class="com.terminalsnippets.actions.OpenSnippetsPopupAction"
            text="Open Terminal Command Snippets Popup"
            description="Opens the Terminal Command Snippets menu">
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift S"/>
        </action>

    </actions>

</idea-plugin>
